{%- doc -%}
  RX lens category picker. Renders selectable cards for the configured lens
  categories (Clear / Sunglasses / Photochromic) and emits the shared RX product
  data JSON (via `rx-product-data`) that every RX component reads at runtime.

  Categories, lens products and per-base-curve mappings are configured on this
  block; the JS filters out cards whose category resolved to no product and
  auto-selects when a single category remains.
{%- enddoc -%}

{%- liquid
  assign heading = block.settings.heading
  assign heading_id = 'RxLensHeading-' | append: block.id
-%}

<rx-lens-selector
  class="rx-lens-selector"
  data-default-category="{{ block.settings.default_category | strip | escape }}"
  {{ block.shopify_attributes }}
>
  {%- if heading != blank -%}
    <p class="rx-lens-selector__heading" id="{{ heading_id }}">{{ heading | escape }}</p>
  {%- endif -%}

  <div
    class="rx-lens-selector__cards"
    role="radiogroup"
    {% if heading != blank %}aria-labelledby="{{ heading_id }}"{% else %}aria-label="Lens type"{% endif %}
  >
    {%- for i in (1..3) -%}
      {%- liquid
        assign key_setting = 'lens_category_' | append: i | append: '_key'
        assign label_setting = 'lens_category_' | append: i | append: '_label'
        assign desc_setting = 'lens_category_' | append: i | append: '_description'
        assign category_key = block.settings[key_setting] | strip
        assign category_label = block.settings[label_setting] | default: category_key
        assign category_desc = block.settings[desc_setting]
      -%}
      {%- if category_key == blank -%}{%- continue -%}{%- endif -%}
      <button
        type="button"
        class="rx-lens-selector__card"
        role="radio"
        aria-checked="false"
        data-category-key="{{ category_key | escape }}"
        on:click="/selectCategory?key={{ category_key | url_encode }}"
      >
        <span class="rx-lens-selector__card-label">{{ category_label | escape }}</span>
        <span class="rx-lens-selector__card-price" data-rx-cat-price hidden></span>
        {%- if category_desc != blank -%}
          <span class="rx-lens-selector__card-desc">{{ category_desc | escape }}</span>
        {%- endif -%}
      </button>
    {%- endfor -%}
  </div>

  {%- comment -%}
    Not closest.product: this block has product-type settings (the lens
    products), and closest.product resolves to those before the page product.
  {%- endcomment -%}
  {% render 'rx-product-data', block: block, product: product %}
</rx-lens-selector>

<script src="{{ 'rx-selectors.js' | asset_url }}" type="module" fetchpriority="low"></script>
<script src="{{ 'rx-recolor.js' | asset_url }}" type="module" fetchpriority="low"></script>

{% stylesheet %}
  rx-lens-selector {
    display: block;
    margin-block: var(--padding-md);
  }

  rx-lens-selector[hidden] {
    display: none;
  }

  .rx-lens-selector__heading {
    margin: 0 0 var(--padding-xs);
    font-size: var(--font-size--sm);
    font-weight: 600;
  }

  .rx-lens-selector__cards {
    display: flex;
    flex-wrap: wrap;
    gap: var(--gap-sm);
  }

  .rx-lens-selector__card {
    flex: 1 1 auto;
    min-width: 0;
    padding: var(--padding-sm) var(--padding-md);
    border: var(--style-border-width-inputs, 1px) solid var(--color-border);
    border-radius: var(--style-border-radius-buttons);
    background: var(--color-background);
    color: var(--color-foreground);
    cursor: pointer;
    text-align: center;
    transition: border-color 0.15s ease, background-color 0.15s ease, color 0.15s ease;
  }

  .rx-lens-selector__card:hover {
    border-color: var(--color-foreground);
  }

  .rx-lens-selector__card--selected {
    border-color: var(--color-foreground);
    background: var(--color-foreground);
    color: var(--color-background);
  }

  .rx-lens-selector__card[hidden] {
    display: none;
  }

  .rx-lens-selector__card-label {
    display: block;
    font-weight: 600;
  }

  .rx-lens-selector__card-price {
    display: block;
    margin-block-start: var(--padding-3xs, 2px);
    font-size: var(--font-size--sm);
  }

  .rx-lens-selector__card-desc {
    display: block;
    margin-block-start: var(--padding-2xs, 4px);
    font-size: var(--font-size--xs);
    opacity: 0.7;
    line-height: 1.35;
  }

  /* Featured image while the lens recolor request is in flight. */
  .rx-recolor-loading {
    opacity: 0.5;
    transition: opacity 0.2s ease;
  }
{% endstylesheet %}

