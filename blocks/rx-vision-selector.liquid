{%- doc -%}
  RX vision type picker (Single Vision / Progressive / Non-RX). Hidden until a
  lens category is chosen in `rx-lens-selector`; the JS reveals it, shows only
  the vision types available for the selected category, and writes the chosen
  vision type + lens product to the shared RX state.
{%- enddoc -%}

{%- liquid
  assign heading = block.settings.heading
  assign heading_id = 'RxVisionHeading-' | append: block.id
  assign sv_label = block.settings.single_vision_label | default: 'Single Vision'
  assign prog_label = block.settings.progressive_label | default: 'Progressive'
  assign non_rx_label = block.settings.non_rx_label | default: 'No Prescription'
  assign show_non_rx = 'true'
  if block.settings.show_non_rx == false
    assign show_non_rx = 'false'
  endif
-%}

<rx-vision-selector
  class="rx-vision-selector"
  data-show-non-rx="{{ show_non_rx }}"
  hidden
  {{ block.shopify_attributes }}
>
  {%- if heading != blank -%}
    <p class="rx-vision-selector__heading" id="{{ heading_id }}">{{ heading | escape }}</p>
  {%- endif -%}

  <div
    class="rx-vision-selector__options"
    role="radiogroup"
    {% if heading != blank %}aria-labelledby="{{ heading_id }}"{% else %}aria-label="Vision type"{% endif %}
  >
    <button
      type="button"
      class="rx-vision-selector__option"
      role="radio"
      aria-checked="false"
      data-vision-type="single_vision"
      on:click="/selectVision?type=single_vision"
    >
      <span class="rx-vision-selector__option-label">{{ sv_label | escape }}</span>
    </button>
    <button
      type="button"
      class="rx-vision-selector__option"
      role="radio"
      aria-checked="false"
      data-vision-type="progressive"
      on:click="/selectVision?type=progressive"
    >
      <span class="rx-vision-selector__option-label">{{ prog_label | escape }}</span>
    </button>
    <button
      type="button"
      class="rx-vision-selector__option"
      role="radio"
      aria-checked="false"
      data-vision-type="non_rx"
      on:click="/selectVision?type=non_rx"
    >
      <span class="rx-vision-selector__option-label">{{ non_rx_label | escape }}</span>
    </button>
  </div>
</rx-vision-selector>

<script src="{{ 'rx-selectors.js' | asset_url }}" type="module" fetchpriority="low"></script>

{% stylesheet %}
  rx-vision-selector {
    display: block;
    margin-block: var(--padding-md);
  }

  rx-vision-selector[hidden] {
    display: none;
  }

  .rx-vision-selector__heading {
    margin: 0 0 var(--padding-xs);
    font-size: var(--font-size--sm);
    font-weight: 600;
  }

  .rx-vision-selector__options {
    display: flex;
    flex-wrap: wrap;
    gap: var(--gap-sm);
  }

  .rx-vision-selector__option {
    flex: 1 1 auto;
    min-width: 0;
    padding: var(--padding-sm) var(--padding-md);
    border: var(--style-border-width-inputs, 1px) solid var(--color-border);
    border-radius: var(--style-border-radius-buttons);
    background: var(--color-background);
    color: var(--color-foreground);
    cursor: pointer;
    text-align: center;
    transition: border-color 0.15s ease, background-color 0.15s ease, color 0.15s ease;
  }

  .rx-vision-selector__option:hover {
    border-color: var(--color-foreground);
  }

  .rx-vision-selector__option--selected {
    border-color: var(--color-foreground);
    background: var(--color-foreground);
    color: var(--color-background);
  }

  .rx-vision-selector__option[hidden] {
    display: none;
  }
{% endstylesheet %}

{% schema %}
{
  "name": "RX Vision Selector",
  "tag": null,
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Vision type"
    },
    {
      "type": "text",
      "id": "single_vision_label",
      "label": "Single vision label",
      "default": "Single Vision"
    },
    {
      "type": "text",
      "id": "progressive_label",
      "label": "Progressive label",
      "default": "Progressive"
    },
    {
      "type": "checkbox",
      "id": "show_non_rx",
      "label": "Offer Non-RX (no prescription)",
      "default": true
    },
    {
      "type": "text",
      "id": "non_rx_label",
      "label": "Non-RX label",
      "default": "No Prescription"
    }
  ],
  "presets": [
    {
      "name": "RX Vision Selector"
    }
  ]
}
{% endschema %}
